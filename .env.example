# Public — bundled into the client apps
EXPO_PUBLIC_SUPABASE_URL=your-supabase-url-here
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Server-side only — never expose to the client
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Supabase admin tooling — used by Supabase CLI / MCP server / management API
SUPABASE_ACCESS_TOKEN=your-supabase-personal-access-token-here
SUPABASE_PROJECT_REF=your-project-ref-here
